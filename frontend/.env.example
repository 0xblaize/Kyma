# ─────────────────────────────────────────────────────────────────────
# AgentOS — environment variables
# Copy this file to `.env.local` and fill in the values you need.
# ─────────────────────────────────────────────────────────────────────

# Demo failsafe — when 1, the synthetic price/portfolio engine runs so
# the dashboard never freezes during the demo recording.
NEXT_PUBLIC_DEMO_FALLBACK=1

# Live LLM toggle — when 1, /api/smc is polled every ~8s and real AI
# reasoning replaces the mock SMC strings in the terminal + chart.
NEXT_PUBLIC_LIVE_LLM=1

# ─────────────────────────────────────────────────────────────────────
# LLM provider (server-side only — never exposed to the browser).
# All three providers below are OpenAI-compatible, so the same code
# works against any of them. Pick ONE block and uncomment it.
# ─────────────────────────────────────────────────────────────────────

# ── Option A · Bitget Qwen (Hackathon Toolkit) ─────────────────────
# Provided to first 500 registered teams via the hackathon credit drop.
# Endpoint is OpenAI-compatible, so this same code path works untouched.
# Models: qwen3.6-plus (default) or qwen3.6-flash (faster, lower quality).
LLM_BASE_URL=https://hackathon.bitgetops.com/v1
LLM_API_KEY=PDqUXm9lyBzziC6m
LLM_MODEL=qwen3.6-plus

# ── Option B · OpenAI (gpt-4o-mini — fastest cheapest path) ─────────
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# ── Option C · Mistral ─────────────────────────────────────────────
# LLM_BASE_URL=https://api.mistral.ai/v1
# LLM_API_KEY=...
# LLM_MODEL=mistral-small-latest
