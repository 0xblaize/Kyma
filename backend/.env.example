# ──────────────────────────────────────────────────────────────
# Kyma Backend — Environment Variables
# Copy this to .env and fill in your values.
# On Railway, add these directly in the dashboard under Variables.
# ──────────────────────────────────────────────────────────────

# CORS — your Vercel frontend URL (no trailing slash)
FRONTEND_URL=https://your-vercel-app.vercel.app

# ── LLM (Bitget Qwen — already configured) ────────────────────
LLM_BASE_URL=https://hackathon.bitgetops.com/v1
LLM_API_KEY=PDqUXm9lyBzziC6m
LLM_MODEL=qwen3.6-plus

# ── Risk Policy Defaults (optional overrides) ─────────────────
MAX_DRAWDOWN_PCT=10.0
RISK_PER_TRADE_PCT=1.0
MAX_LOT_SIZE_USDT=500.0

# ── Binance (public data only — no keys needed) ───────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=

# PORT is automatically injected by Railway — do NOT set this manually
